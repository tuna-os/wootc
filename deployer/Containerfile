# Deployer initramfs Containerfile
# Builds a minimal initramfs that mounts a root.disk loop file from NTFS
# and runs fisherman to deploy a bootc OCI image into it.
#
# Fisherman handles all the real work: partitioning, formatting,
# bootc install to-filesystem, Flatpaks, hostname, kernel cmdline.
# The wootc deployer just sets up the loop device and points fisherman at it.
#
# Build:
#   podman build -t wootc-deployer .
#   podman run --rm -v $(pwd)/out:/out wootc-deployer
#
# Output: out/vmlinuz, out/initramfs.img (~200MB with fisherman)

FROM quay.io/fedora/fedora:44 AS builder

# ── Install system packages ─────────────────────────────────────────────────
RUN dnf install -y \
    systemd systemd-udev dracut dracut-network \
    podman skopeo \
    util-linux e2fsprogs dosfstools \
    ntfs-3g ntfsprogs fuse3 \
    NetworkManager iproute dhcp-client \
    curl ca-certificates jq \
    && dnf clean all

# ── Build fisherman statically ──────────────────────────────────────────────
# Fisherman is a Go binary — build it statically so it needs no runtime deps.
FROM golang:1.24 AS gobuilder
COPY fisherman /src/fisherman
WORKDIR /src/fisherman
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /fisherman ./cmd/fisherman/

# ── Copy fisherman into the initramfs builder ───────────────────────────────
FROM builder
COPY --from=gobuilder /fisherman /usr/bin/fisherman

# ── Deployer script ─────────────────────────────────────────────────────────
COPY deploy.sh /usr/bin/wootc-deploy
RUN chmod +x /usr/bin/wootc-deploy

# ── Init script (PID 1 in the initramfs) ────────────────────────────────────
COPY init /init
RUN chmod +x /init

# ── Dracut module ───────────────────────────────────────────────────────────
RUN mkdir -p /usr/lib/dracut/modules.d/99wootc
COPY module-setup.sh /usr/lib/dracut/modules.d/99wootc/module-setup.sh
RUN chmod +x /usr/lib/dracut/modules.d/99wootc/module-setup.sh

# ── Build the initramfs ─────────────────────────────────────────────────────
RUN KERNEL_VER=$(ls /lib/modules | head -1) && \
    dracut \
        --force \
        --no-hostonly \
        --add "network kernel-modules kernel-modules-extra 99wootc" \
        --install "podman skopeo fisherman \
                   ntfs-3g mount.ntfs-3g \
                   parted mkfs.ext4 mkfs.vfat mkfs.xfs \
                   losetup dmsetup \
                   curl dhclient ip NetworkManager jq" \
        --kernel-cmdline "rd.neednet=1 ip=dhcp quiet" \
        /out/initramfs.img \
        "$KERNEL_VER"

RUN cp /boot/vmlinuz-* /out/vmlinuz 2>/dev/null || \
    cp /lib/modules/*/vmlinuz /out/vmlinuz 2>/dev/null || true

VOLUME /out
