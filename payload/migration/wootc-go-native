#!/bin/bash
# /usr/local/bin/wootc-go-native — Phase 3: the "commit to Linux" stage.
#
# On a running Phase-2 system (Linux booting from root.disk, a loopback VHDX on
# the Windows NTFS partition), this is where the user decides to move to Linux
# only: graduate the root filesystem onto a real native partition and, if they
# choose, delete the Windows partition and grow Linux to reclaim the space
# (SPEC §4.2 stages 5-6).
#
# SAFETY MODEL. Stage 6 is irreversible and destroys Windows, so this tool is
# built inside-out: the analysis path (`plan`, `check`) is complete and safe to
# run anywhere; the destructive path (`migrate`) is GUARDED and deliberately
# not enabled until it has been proven against a booted Phase-2 system on real
# hardware (verification ladder rung 2 → rung 3). It refuses to touch a disk
# until then, by design — better an explicit "not yet" than a blind repartition.
#
#   wootc-go-native plan            analyze layout + print the plan (safe)
#   wootc-go-native check           exit 0 if preconditions for going native hold
#   wootc-go-native migrate ...     GUARDED — destructive repartition (stub)
#
# Test hooks (fixtures, no real disks): WOOTC_GN_ROOT_SRC, WOOTC_GN_LSBLK,
# WOOTC_GN_HOSTCONF, WOOTC_GN_HOME, WOOTC_GN_FORCE_LOOP.

set -Eeuo pipefail

# GUI launchers and QEMU Guest Agent commands inherit a service-manager PATH,
# not an interactive shell's. Bluefin installs administrative tools such as
# podman, bootc, sfdisk, and efibootmgr under /usr/sbin; without an explicit
# system PATH Phase 3 reaches its verified blank disk and then fails with
# `podman: command not found` despite the binary being installed.
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin${PATH:+:$PATH}"

log()  { printf '[wootc-go-native] %s\n' "$*" >&2; }
die()  { printf '[wootc-go-native] ERROR: %s\n' "$*" >&2; exit 1; }

HOSTCONF="${WOOTC_GN_HOSTCONF:-/etc/wootc/host-esp.conf}"

# root_source — the block device / image backing "/". On a Phase-2 system this
# is the NBD-attached root.disk (/dev/nbd0pN); on a native system it is a real
# partition. The distinction is the whole point of "are we still on loopback?".
root_source() {
    if [[ -n "${WOOTC_GN_ROOT_SRC:-}" ]]; then echo "$WOOTC_GN_ROOT_SRC"; return; fi
    findmnt -n -o SOURCE / 2>/dev/null || true
}

# on_loopback — true when Linux is still hosted inside root.disk on NTFS.
on_loopback() {
    [[ "${WOOTC_GN_FORCE_LOOP:-}" == "1" ]] && return 0
    [[ "${WOOTC_GN_FORCE_LOOP:-}" == "0" ]] && return 1
    local src; src=$(root_source)
    [[ "$src" == /dev/nbd* ]] && return 0
    [[ -e /run/wootc-loop-attached ]] && return 0
    grep -qE '(^| )(loop|wootc\.rootdisk)=' /proc/cmdline 2>/dev/null && return 0
    return 1
}

# converted_folders — which user media folders have been made native already
# (stage 4). Uses the ~/.config/wootc/converted-* markers wootc-convert-dir writes.
converted_folders() {
    local home="${WOOTC_GN_HOME:-${HOME:-/root}}" f
    for f in "$home"/.config/wootc/converted-*; do
        [[ -e "$f" ]] || continue
        basename "$f" | sed 's/^converted-//'
    done
}

# ── plan ────────────────────────────────────────────────────────────────────
cmd_plan() {
    local src loop hostuuid bootloader
    src=$(root_source)
    if on_loopback; then loop="yes"; else loop="no"; fi
    hostuuid=""; bootloader=""
    if [[ -r "$HOSTCONF" ]]; then
        hostuuid=$(grep -oP 'HOST_ESP_UUID=\K.*' "$HOSTCONF" 2>/dev/null || true)
        bootloader=$(grep -oP 'BOOTLOADER=\K.*' "$HOSTCONF" 2>/dev/null || true)
    fi
    local converted; converted=$(converted_folders | paste -sd, - 2>/dev/null || true)

    echo   "wootc — Move to Linux only (Phase 3)"
    echo   "───────────────────────────────────"
    printf 'Root filesystem source : %s\n' "${src:-unknown}"
    printf 'Still on Windows NTFS  : %s\n' "$loop"
    printf 'Host ESP UUID          : %s\n' "${hostuuid:-unknown}"
    printf 'Host bootloader        : %s\n' "${bootloader:-unknown}"
    printf 'Folders made native    : %s\n' "${converted:-none yet}"
    echo
    if [[ "$loop" == "no" ]]; then
        echo "This system already runs from a native Linux partition — nothing to graduate."
        echo "If Windows is still present you can reclaim its space with:  migrate --reclaim"
        return 0
    fi
    cat <<'PLAN'
Planned stages when you commit:

  5. Graduate root to native
     • Deploy the same bootc image onto a real Linux partition (no re-download —
       the OCI content already lives in root.disk).
     • Copy your home data onto it. Nothing on Windows is touched yet.
     • Switch the boot entry from the root.disk loopback chain to the native
       partition. (Reversible: root.disk stays until stage 6.)

  6. Remove Windows  (IRREVERSIBLE)
     • Only offered once every folder you use is native (see "Folders made
       native" above) and a rollback snapshot exists.
     • Delete the Windows partition, grow Linux to fill the disk, and remove the
       Windows Boot Manager / BCD one-shot chain.

Run 'wootc-go-native check' to see whether the safety preconditions are met.
PLAN
}

# ── check ───────────────────────────────────────────────────────────────────
# Exit 0 only if it is SAFE to begin going native. Prints each gate's result.
cmd_check() {
    local ok=0
    if on_loopback; then
        echo "[ok]   running from root.disk (loopback) — graduation applies"
    else
        echo "[skip] already native — stage 5 not applicable"
    fi
    if [[ -r "$HOSTCONF" ]]; then
        echo "[ok]   host layout recorded ($HOSTCONF)"
    else
        echo "[warn] $HOSTCONF missing — cannot locate the Windows ESP/partition"
        ok=1
    fi
    # A rollback snapshot is required before any destructive step.
    if command -v btrfs >/dev/null && btrfs subvolume show / >/dev/null 2>&1; then
        echo "[ok]   btrfs root — snapshot rollback available for stage 5/6"
    else
        echo "[warn] no btrfs snapshot capability detected — stage 6 stays disabled"
    fi
    local conv; conv=$(converted_folders | wc -l)
    echo "[info] $conv user folder(s) already native"
    return $ok
}

# ── disk layout discovery ────────────────────────────────────────────────────
# Populate DISK (whole device with Windows), ESP_DEV, NTFS_DEV. On a Phase-2
# system root is /dev/nbdNpM (a loopback of root.disk inside the NTFS), so the
# real disk is found via the host ESP UUID recorded at deploy time. Test hooks:
# WOOTC_GN_DISK / WOOTC_GN_ESP / WOOTC_GN_NTFS bypass the probing.
DISK=""; ESP_DEV=""; NTFS_DEV=""
discover_layout() {
    DISK="${WOOTC_GN_DISK:-}"; ESP_DEV="${WOOTC_GN_ESP:-}"; NTFS_DEV="${WOOTC_GN_NTFS:-}"
    if [[ -z "$ESP_DEV" && -r "$HOSTCONF" ]]; then
        local uuid; uuid=$(grep -oP 'HOST_ESP_UUID=\K.*' "$HOSTCONF" 2>/dev/null || true)
        [[ -n "$uuid" ]] && ESP_DEV=$(blkid -U "$uuid" 2>/dev/null || true)
    fi
    [[ -n "$DISK" || -z "$ESP_DEV" ]] || DISK="/dev/$(lsblk -no PKNAME "$ESP_DEV" 2>/dev/null | head -1)"
    if [[ -z "$NTFS_DEV" && -n "$DISK" ]]; then
        # The largest NTFS partition on that disk is where root.disk lives.
        NTFS_DEV=$(lsblk -bnro PATH,FSTYPE,SIZE "$DISK" 2>/dev/null \
            | awk '$2=="ntfs"||$2=="ntfs3"{print $3, $1}' | sort -nr | head -1 | awk '{print $2}')
    fi
    [[ -n "$DISK" && -n "$NTFS_DEV" ]]
}

# next_partnum — the next free partition number on DISK.
next_partnum() {
    local n; n=$(lsblk -nro NAME "$DISK" 2>/dev/null | grep -oE '[0-9]+$' | sort -n | tail -1)
    echo $(( ${n:-0} + 1 ))
}

# graduate_plan — the exact command sequence to move onto a native partition
# while keeping Windows (reversible). Printed for review; run only with execute.
graduate_plan() {
    local shrink_gib="${WOOTC_GN_SHRINK_GIB:-0}" newpart="${DISK}$(next_partnum)"
    local localref="containers-storage:$(bootc_local_imgref)"
    cat <<PLAN
Graduate to native (dual-boot — Windows stays, fully reversible)
Disk: $DISK   Windows NTFS: $NTFS_DEV   ESP: $ESP_DEV
New native partition: $newpart

Commands (each verified before the next):
  1. Snapshot for rollback:
       btrfs subvolume snapshot -r / /.wootc-prenative   (or: bootc rollback point)
  2. Make room by shrinking Windows (only if no free tail space):
       ntfsresize --info $NTFS_DEV        # confirm shrinkable
       ntfsresize --size -${shrink_gib}Gi $NTFS_DEV
       sfdisk -N <win#> $DISK             # shrink the partition entry to match
  3. Create + format the native partition:
       sfdisk --append $DISK  <<< 'type=linux'      # → $newpart
       mkfs.xfs -f $newpart
  4. Install the OS onto it from the ALREADY-LOCAL image (no download):
       mount $newpart /mnt/native
       bootc install to-filesystem --source-imgref $localref \\
           --acknowledge-destructive --generic-image \\
           --karg rw --root-mount-spec UUID=<new> /mnt/native
  5. Migrate your data off root.disk:
       rsync -aHAX --info=progress2 /home/ /mnt/native/home/
  6. Point the boot default at the native partition (bootupd owns the ESP):
       bootupctl backend generate-update-metadata /mnt/native
       efibootmgr -c -d $DISK -p 1 -L 'TunaOS' -l '\\EFI\\almalinux\\shimx64.efi'
       efibootmgr -o <native>,<windows>          # native first, Windows kept
  7. Reboot. You are now on the native partition; root.disk + Windows remain
     for rollback until you run 'migrate --reclaim'.
PLAN
}

# reclaim_plan — stage 6, printed only when data-is-native preconditions hold.
reclaim_plan() {
    cat <<PLAN
Remove Windows and reclaim its space (IRREVERSIBLE)
Disk: $DISK   deleting: $NTFS_DEV (Windows) + root.disk inside it

Commands:
  1. Refuse unless already running native (not from root.disk) AND every used
     folder is converted (see 'check').
  2. Delete the Windows partition:  sfdisk --delete $DISK <win#>
  3. Grow the native partition into the freed space:
       growpart $DISK <native#>  &&  xfs_growfs /
  4. Remove the Windows Boot Manager entry:  efibootmgr -Bb <windows>
PLAN
}

# bootc_local_imgref — the deployer's authoritative registry origin.  `bootc
# status` reports the transient localhost/wootc-ntfs-injected tag when Phase 2
# needed an NTFS compatibility layer, but that tag belonged to the deployer's
# separate containers-storage and cannot be pulled in the installed system.
bootc_local_imgref() {
    local configured=""
    if [[ -r "$HOSTCONF" ]]; then
        configured=$(grep -oP '^SOURCE_IMAGE_REF=\K\S+' "$HOSTCONF" 2>/dev/null | head -1 || true)
    fi
    if [[ "$configured" =~ ^[a-zA-Z0-9._-]+([.:][a-zA-Z0-9._-]+)*/[a-zA-Z0-9._/-]+(:[a-zA-Z0-9._-]+|@sha256:[a-fA-F0-9]{64})?$ ]]; then
        echo "$configured"
        return 0
    fi
    bootc status --json 2>/dev/null | grep -oP '"image":\s*"\K[^"]+' | head -1 \
        || echo "ghcr.io/tuna-os/yellowfin:gnome"
}

# graduate_to_disk_execute — install the running OS onto a whole TARGET disk via
# bootc (reusing the local image, same as the deployer), migrate /home, and let
# UEFI boot it. Reversible: Windows + root.disk on the original disk are
# untouched, so this is the dual-boot graduate for a spare/second drive.
graduate_to_disk_execute() {
    local target="$1" img filesystem=xfs newroot mnt=/run/wootc-native
    [[ -b "$target" ]] || die "not a block device: $target"
    [[ "$target" != "$DISK" ]] || die "refusing to install onto the Windows disk ($DISK)"
    img=$(bootc_local_imgref)
    if [[ -r "$HOSTCONF" ]]; then
        filesystem=$(grep -oP '^SOURCE_FILESYSTEM=\K\S+' "$HOSTCONF" 2>/dev/null | head -1 || true)
    fi
    filesystem=${filesystem:-xfs}
    case "$filesystem" in xfs|ext4|btrfs) ;; *) die "invalid recorded filesystem: $filesystem" ;; esac
    log "Installing $img onto $target as $filesystem (wipes $target only)…"
    # Same mechanism as the initial deploy: run bootc from the local image with
    # /dev passed through. bootc partitions the target (ESP+boot+root), installs
    # the ostree deployment, and lays the bootloader via bootupd.
    podman run --rm --privileged --pid=host --security-opt label=disable --net=host \
        -v /var/lib/containers:/var/lib/containers -v /dev:/dev -v /var/tmp:/var/tmp \
        "$img" bootc install to-disk --generic-image --wipe --filesystem "$filesystem" --karg rw "$target" \
        || die "bootc install to-disk failed"

    # Migrate /home into the new install. On ostree, /home → /var/home in the
    # stateroot (…/ostree/deploy/<stateroot>/var/home).
    newroot=$(lsblk -bnro PATH,SIZE "$target" 2>/dev/null | sort -k2 -nr | head -1 | awk '{print $1}')
    log "Migrating /home to the native install on $newroot…"
    mkdir -p "$mnt"; mount "$newroot" "$mnt" || die "cannot mount $newroot"
    local dest="$mnt/home"
    local dep; dep=$(ls -d "$mnt"/ostree/deploy/*/deploy/*.0 2>/dev/null | head -1)
    [[ -n "$dep" ]] && dest="$(dirname "$(dirname "$dep")")/var/home"
    mkdir -p "$dest"
    if command -v rsync >/dev/null; then
        rsync -aHAX /home/ "$dest/" 2>/dev/null || true
    else
        cp -a /home/. "$dest/" 2>/dev/null || true
    fi
    sync; umount "$mnt" 2>/dev/null || true

    log "Graduate complete. UEFI boot entries now include the native install:"
    efibootmgr 2>/dev/null | grep -iE "almalinux|tunaos|fedora|Linux|Boot0" | head -8
    log "Reboot to run natively from $target. Windows + root.disk remain for rollback."
}

# ── migrate ──────────────────────────────────────────────────────────────────
# Default is a DRY RUN: print the exact command plan and stop. Real execution
# is gated behind --execute + WOOTC_GN_ALLOW_DESTRUCTIVE=1 + preconditions and
# is intentionally not enabled until validated against a booted Phase-2 system
# (rung 3): a repartition bug must never run blind against a user's disk.
cmd_migrate() {
    local mode="" execute=false to_disk=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dual-boot) mode="dual-boot" ;;
            --reclaim)   mode="reclaim" ;;
            --to-disk)   mode="dual-boot"; to_disk="$2"; shift ;;
            --execute|--i-understand) execute=true ;;
            *) die "unknown migrate arg: $1" ;;
        esac
        shift
    done
    [[ -n "$mode" ]] || die "choose --dual-boot [--to-disk DEV] (keep Windows) or --reclaim (delete Windows)"

    if ! discover_layout; then
        die "could not locate the Windows disk/NTFS (need $HOSTCONF or WOOTC_GN_DISK/NTFS)"
    fi

    # Reclaim's hard data-safety gate: never delete Windows while data still
    # lives only there. Running native + converted folders are preconditions.
    if [[ "$mode" == "reclaim" ]]; then
        if on_loopback; then
            die "refusing --reclaim: still running from root.disk. Run --dual-boot and reboot native first."
        fi
        [[ "$(converted_folders | wc -l)" -gt 0 ]] \
            || die "refusing --reclaim: no folders verified native (see 'check'). Convert your data first."
    fi

    echo "── DRY RUN ─────────────────────────────────────────────────────────"
    [[ "$mode" == "dual-boot" ]] && graduate_plan || reclaim_plan
    echo "────────────────────────────────────────────────────────────────────"

    if [[ "$execute" != true ]]; then
        echo "Dry run only. Re-run with --execute to perform these steps."
        return 0
    fi
    # These are disposable-VM test targets, but keep the flag so a stray
    # --execute on a real box (no flag set) can't repartition it.
    if [[ "${WOOTC_GN_ALLOW_DESTRUCTIVE:-0}" != "1" ]]; then
        die "--execute requires WOOTC_GN_ALLOW_DESTRUCTIVE=1 (set only in the test harness)"
    fi
    # The implemented, testable execution path: graduate onto a spare target
    # disk (bootc install to-disk from the local image). Same-disk shrink/reclaim
    # runs from a graduate-deployer and is wired separately.
    if [[ -n "$to_disk" ]]; then
        graduate_to_disk_execute "$to_disk"
        return 0
    fi
    die "in-place (shrink Windows) graduate runs from the graduate-deployer; use --to-disk DEV for the spare-drive path"
}

# ── status --json ────────────────────────────────────────────────────────────
# Machine-readable state for the GUI (wootc-go-native-gui). Read-only and safe
# to run anywhere; every field mirrors what `plan`/`check` print as text.
cmd_status() {
    local src loop hostuuid bootloader snapshot hostconf reclaim_ok
    src=$(root_source)
    on_loopback && loop=1 || loop=0
    hostuuid=""; bootloader=""; hostconf=0
    if [[ -r "$HOSTCONF" ]]; then
        hostuuid=$(grep -oP 'HOST_ESP_UUID=\K.*' "$HOSTCONF" 2>/dev/null || true)
        bootloader=$(grep -oP 'BOOTLOADER=\K.*' "$HOSTCONF" 2>/dev/null || true)
        hostconf=1
    fi
    if command -v btrfs >/dev/null && btrfs subvolume show / >/dev/null 2>&1; then snapshot=1; else snapshot=0; fi
    # reclaim is offered only once native (off loopback) AND at least one folder
    # is verified native — the same hard gate cmd_migrate enforces.
    local nconv; nconv=$(converted_folders | grep -c . || true)
    if [[ "$loop" == 0 && "${nconv:-0}" -gt 0 ]]; then reclaim_ok=1; else reclaim_ok=0; fi

    GN_SRC="$src" GN_LOOP="$loop" GN_UUID="$hostuuid" GN_BL="$bootloader" \
    GN_HOSTCONF="$hostconf" GN_SNAP="$snapshot" GN_RECLAIM="$reclaim_ok" \
    GN_FOLDERS="$(converted_folders | paste -sd, - 2>/dev/null || true)" \
    python3 - <<'PY'
import json, os
folders = [f for f in os.environ.get("GN_FOLDERS", "").split(",") if f]
print(json.dumps({
    "onLoopback":      os.environ["GN_LOOP"] == "1",
    "rootSource":      os.environ.get("GN_SRC", "") or None,
    "hostEspUuid":     os.environ.get("GN_UUID", "") or None,
    "hostBootloader":  os.environ.get("GN_BL", "") or None,
    "convertedFolders": folders,
    "gates": {
        "hostLayoutRecorded": os.environ["GN_HOSTCONF"] == "1",
        "snapshotCapable":    os.environ["GN_SNAP"] == "1",
        "dataIsNative":       len(folders) > 0,
    },
    "canGraduate": os.environ["GN_LOOP"] == "1",
    "canReclaim":  os.environ["GN_RECLAIM"] == "1",
}, indent=2))
PY
}

case "${1:-plan}" in
    plan)    shift 2>/dev/null || true; cmd_plan "$@" ;;
    check)   shift; cmd_check "$@" ;;
    status)  shift; cmd_status "$@" ;;
    migrate) shift; cmd_migrate "$@" ;;
    -h|--help) sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//' ;;
    *) die "unknown subcommand: $1 (plan|check|status|migrate)" ;;
esac
