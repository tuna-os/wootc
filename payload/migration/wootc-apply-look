#!/bin/bash
# /usr/local/bin/wootc-apply-look
# Windows-Style Mode (SPEC §4.4): apply the look collected from Windows
# (wallpaper, dark mode, accent color) to the user's Linux desktop.
# Runs once per user via /etc/xdg/autostart (self-guards with a marker).
#
# The per-DE knowledge lives in apply_<de>() functions — the "database"
# of how each desktop environment receives each setting. Adding a DE is
# adding one function; nothing else changes. Detection uses
# XDG_CURRENT_DESKTOP (colon-separated list, case-insensitive).
#
# Test hook: WOOTC_DRYRUN=1 prints the commands instead of running them,
# so the mapping is testable in a container with no desktop at all.

set -Eeuo pipefail

log() { printf '[wootc-apply-look] %s\n' "$*"; }

SLURP_DIR="${WOOTC_SLURP_DIR:-/usr/share/wootc/slurp}"
MARKER="${WOOTC_LOOK_MARKER:-$HOME/.config/wootc/look-applied}"

[[ -f "$SLURP_DIR/slurp.json" ]] || { log "no slurp data; nothing to apply"; exit 0; }
[[ -e "$MARKER" ]] && { log "already applied for $USER"; exit 0; }

run() {
    if [[ "${WOOTC_DRYRUN:-0}" = "1" ]]; then
        printf 'DRYRUN: %s\n' "$*"
    else
        "$@" || log "non-fatal: $* failed"
    fi
}

json() { python3 -c "
import json, sys
d = json.load(open('$SLURP_DIR/slurp.json'))
v = d.get('$1', '')
print(v if v is not None else '')
"; }

WALLPAPER=""
shopt -s nullglob
for w in "$SLURP_DIR"/wallpaper.*; do WALLPAPER="$w"; break; done
shopt -u nullglob
DARK=$(json darkMode)          # "true" / "false" / ""
ACCENT=$(json accentColor)     # "#RRGGBB" or ""
KBD=$(json keyboardLayout)     # xkb code, e.g. "us" / "de" / ""

# ── Taskbar/desktop app bring-over (SPEC §4.4) ──────────────────────────────
# Emits `bucket exe name` lines for pinned taskbar and desktop shortcuts.
pinned_lines() {
    python3 - "$SLURP_DIR/slurp.json" <<'PYEOF'
import json, sys
try:
    d = json.load(open(sys.argv[1]))
except Exception:
    sys.exit(0)
for bucket in ("taskbarApps", "desktopApps"):
    for a in d.get(bucket, []) or []:
        exe = (a.get("exe") or "").lower()
        name = (a.get("name") or "").replace("\n", " ").strip()
        print(f"{bucket}\t{exe}\t{name}")
PYEOF
}

# map_candidates <exe> <name> — echo space-separated candidate .desktop ids
# (without the .desktop suffix), most-preferred first. Matches on the Windows
# target exe, falling back to keywords in the shortcut's friendly name so UWP
# pins (which have no TargetPath) still resolve.
map_candidates() {
    local exe="$1" name="${2,,}" c=""
    case "$exe" in
        firefox.exe)              c="org.mozilla.firefox firefox" ;;
        chrome.exe)               c="com.google.Chrome google-chrome google-chrome-stable chromium" ;;
        msedge.exe|microsoftedge*.exe) c="com.microsoft.Edge microsoft-edge com.google.Chrome org.mozilla.firefox" ;;
        brave.exe)                c="com.brave.Browser brave-browser" ;;
        opera.exe)                c="com.opera.Opera opera" ;;
        code.exe)                 c="com.visualstudio.code code code-oss" ;;
        discord.exe|update.exe)   [[ "$name" == *discord* ]] && c="com.discordapp.Discord discord" ;;
        spotify.exe)              c="com.spotify.Client spotify" ;;
        slack.exe)                c="com.slack.Slack slack" ;;
        teams.exe|ms-teams.exe)   c="com.github.IsmaelMartinez.teams_for_linux teams-for-linux" ;;
        telegram.exe)             c="org.telegram.desktop telegram-desktop" ;;
        signal.exe)               c="org.signal.Signal signal-desktop" ;;
        thunderbird.exe)          c="org.mozilla.Thunderbird thunderbird" ;;
        zoom.exe)                 c="us.zoom.Zoom Zoom zoom" ;;
        obs64.exe|obs32.exe|obs.exe) c="com.obsproject.Studio obs" ;;
        steam.exe)                c="com.valvesoftware.Steam steam" ;;
        vlc.exe)                  c="org.videolan.VLC vlc" ;;
        winword.exe)              c="org.libreoffice.LibreOffice-writer libreoffice-writer org.libreoffice.LibreOffice" ;;
        excel.exe)                c="org.libreoffice.LibreOffice-calc libreoffice-calc org.libreoffice.LibreOffice" ;;
        powerpnt.exe)             c="org.libreoffice.LibreOffice-impress libreoffice-impress org.libreoffice.LibreOffice" ;;
        acrord32.exe|acrobat.exe) c="org.gnome.Evince org.gnome.Papers evince" ;;
        notepad.exe|notepad++.exe) c="org.gnome.TextEditor org.gnome.gedit gedit" ;;
        wt.exe|windowsterminal.exe|cmd.exe|powershell.exe) c="org.gnome.Ptyxis org.gnome.Console org.gnome.Terminal konsole" ;;
        explorer.exe|"")          : ;;  # generic shell target — resolve by name below
    esac
    if [[ -z "$c" ]]; then
        case "$name" in
            *firefox*)   c="org.mozilla.firefox firefox" ;;
            *chrome*)    c="com.google.Chrome google-chrome" ;;
            *edge*)      c="com.microsoft.Edge microsoft-edge" ;;
            *whatsapp*)  c="com.rtosta.zapzap io.github.mimbrero.WhatsAppDesktop" ;;
            *telegram*)  c="org.telegram.desktop telegram-desktop" ;;
            *spotify*)   c="com.spotify.Client spotify" ;;
            *discord*)   c="com.discordapp.Discord discord" ;;
            *outlook*|*mail*) c="org.mozilla.Thunderbird thunderbird" ;;
            *word*)      c="org.libreoffice.LibreOffice-writer libreoffice-writer" ;;
            *excel*)     c="org.libreoffice.LibreOffice-calc libreoffice-calc" ;;
            *powerpoint*) c="org.libreoffice.LibreOffice-impress libreoffice-impress" ;;
            *steam*)     c="com.valvesoftware.Steam steam" ;;
            *file?explorer*|*explorer*) c="org.gnome.Nautilus org.kde.dolphin nautilus" ;;
        esac
    fi
    echo "$c"
}

# desktop_dirs — where installed .desktop files live (system, user, flatpak).
desktop_dirs() {
    printf '%s\n' \
        /usr/share/applications \
        /usr/local/share/applications \
        "$HOME/.local/share/applications" \
        /var/lib/flatpak/exports/share/applications \
        "$HOME/.local/share/flatpak/exports/share/applications"
}

# resolve_desktop — echo the first candidate .desktop id that exists, "" if none.
resolve_desktop() {
    local id
    for id in $(map_candidates "$1" "$2"); do
        while IFS= read -r dir; do
            [[ -f "$dir/$id.desktop" ]] && { echo "$id.desktop"; return; }
        done < <(desktop_dirs)
    done
    echo ""
}

# Map an #RRGGBB accent to the nearest named accent for DEs with fixed
# palettes (GNOME 47+). Euclidean distance in RGB is good enough here.
nearest_gnome_accent() {
    python3 - "$1" <<'PYEOF'
import sys
palette = {
    "blue": (53, 132, 228), "teal": (33, 144, 164), "green": (58, 148, 74),
    "yellow": (200, 136, 0), "orange": (237, 91, 0), "red": (230, 45, 66),
    "pink": (213, 97, 153), "purple": (145, 65, 172), "slate": (111, 131, 150),
}
h = sys.argv[1].lstrip('#')
try:
    r, g, b = int(h[0:2], 16), int(h[2:4], 16), int(h[4:6], 16)
except (ValueError, IndexError):
    print("blue"); sys.exit()
print(min(palette, key=lambda n: sum((a - c) ** 2 for a, c in zip(palette[n], (r, g, b)))))
PYEOF
}

# ── Per-DE database ─────────────────────────────────────────────────────────

apply_gnome() {
    if [[ -n "$WALLPAPER" ]]; then
        run gsettings set org.gnome.desktop.background picture-uri "file://$WALLPAPER"
        run gsettings set org.gnome.desktop.background picture-uri-dark "file://$WALLPAPER"
        run gsettings set org.gnome.desktop.background picture-options zoom
    fi
    if [[ "$DARK" = "true" ]]; then
        run gsettings set org.gnome.desktop.interface color-scheme prefer-dark
    elif [[ "$DARK" = "false" ]]; then
        run gsettings set org.gnome.desktop.interface color-scheme default
    fi
    if [[ -n "$ACCENT" ]]; then
        run gsettings set org.gnome.desktop.interface accent-color "$(nearest_gnome_accent "$ACCENT")"
    fi
    if [[ -n "$KBD" ]]; then
        run gsettings set org.gnome.desktop.input-sources sources "[('xkb', '$KBD')]"
    fi
}

# resolved_taskbar_ids — the ordered, deduped list of installed .desktop ids
# the user's Windows taskbar pins map to (one per line). Shared by every DE's
# favorites/panel mapping so the pin→app database lives in exactly one place.
resolved_taskbar_ids() {
    local ids=() bucket exe name id
    while IFS=$'\t' read -r bucket exe name; do
        [[ "$bucket" == "taskbarApps" ]] || continue
        id=$(resolve_desktop "$exe" "$name")
        [[ -n "$id" ]] || continue
        printf '%s\n' "${ids[@]}" | grep -qxF "$id" 2>/dev/null || ids+=("$id")
    done < <(pinned_lines)
    printf '%s\n' "${ids[@]}"
}

# apply_gnome_favorites — set the dash favorites to the ordered, resolved
# taskbar pins, appended to the distro defaults (dedup, order preserved).
apply_gnome_favorites() {
    local ids=() i gv="[" first=1
    mapfile -t ids < <(resolved_taskbar_ids)
    [[ ${#ids[@]} -gt 0 ]] || { log "no taskbar pins resolved to installed apps"; return 0; }
    for i in "${ids[@]}"; do
        [[ $first -eq 1 ]] && first=0 || gv+=", "
        gv+="'$i'"
    done
    gv+="]"
    run gsettings set org.gnome.shell favorite-apps "$gv"
    log "dock favorites set from ${#ids[@]} taskbar pins"
}

# apply_kde_favorites — pin the same apps to the KDE Plasma panel's Task
# Manager (parity with the GNOME dash). Plasma stores launchers on the
# icons-only/task-manager applet inside plasma-org.kde.plasma.desktop-appletsrc
# as launchers=applications:<id>,… Find that applet's config group and set it.
# Pre-session (autostart) the file may already carry Plasma's defaults; we
# append our pins after them, deduped, so nothing the image shipped is lost.
apply_kde_favorites() {
    local ids=() i
    mapfile -t ids < <(resolved_taskbar_ids)
    [[ ${#ids[@]} -gt 0 ]] || { log "no taskbar pins resolved to installed apps"; return 0; }

    # Build the launchers value: applications:<id>,applications:<id>,…
    local launchers="" first=1
    for i in "${ids[@]}"; do
        [[ $first -eq 1 ]] && first=0 || launchers+=","
        launchers+="applications:$i"
    done

    # Locate the Task Manager applet group in the appletsrc so we target the
    # real panel widget rather than guessing indices. Fall back to the common
    # default group so a first-boot appletsrc still gets the launchers.
    local appletsrc="$HOME/.config/plasma-org.kde.plasma.desktop-appletsrc"
    local grp=""
    if [[ -f "$appletsrc" ]]; then
        grp=$(awk '
            /^\[/{g=$0}
            /plugin=org\.kde\.plasma\.(icontasks|taskmanager)/{print g; exit}
        ' "$appletsrc")
    fi
    # awk prints e.g. [Containments][2][Applets][5]; turn it into the repeated
    # --group args kwriteconfig6 expects, plus the Configuration/General leaf.
    local -a gargs=()
    if [[ -n "$grp" ]]; then
        local tok
        while IFS= read -r tok; do [[ -n "$tok" ]] && gargs+=(--group "$tok"); done \
            < <(printf '%s\n' "$grp" | grep -oE '\[[^]]+\]' | tr -d '[]')
        gargs+=(--group Configuration --group General)
    else
        # Sensible default: first containment's first task-manager-shaped applet.
        gargs=(--group Containments --group 1 --group Applets --group 1 \
               --group Configuration --group General)
        log "kde: task-manager applet not found in appletsrc; using default group"
    fi

    run kwriteconfig6 --file plasma-org.kde.plasma.desktop-appletsrc \
        "${gargs[@]}" --key launchers "$launchers"
    log "panel launchers set from ${#ids[@]} taskbar pins"
}

apply_kde() {
    if [[ -n "$WALLPAPER" ]]; then
        run plasma-apply-wallpaperimage "$WALLPAPER"
    fi
    if [[ "$DARK" = "true" ]]; then
        run plasma-apply-colorscheme BreezeDark
    elif [[ "$DARK" = "false" ]]; then
        run plasma-apply-colorscheme BreezeLight
    fi
    if [[ -n "$ACCENT" ]]; then
        run kwriteconfig6 --file kdeglobals --group General --key AccentColor \
            "$(printf '%d,%d,%d' 0x${ACCENT:1:2} 0x${ACCENT:3:2} 0x${ACCENT:5:2})"
    fi
    if [[ -n "$KBD" ]]; then
        run kwriteconfig6 --file kxkbrc --group Layout --key LayoutList "$KBD"
        run kwriteconfig6 --file kxkbrc --group Layout --key Use true
    fi
}

# apply_desktop_shortcuts — recreate the user's desktop shortcuts as launchers
# for the apps that exist on Linux. DE-agnostic (~/Desktop + trusted flag).
apply_desktop_shortcuts() {
    local ddir="$HOME/Desktop" bucket exe name id src placed=0
    [[ -d "$ddir" ]] || { mkdir -p "$ddir" 2>/dev/null || return; }
    while IFS=$'\t' read -r bucket exe name; do
        [[ "$bucket" == "desktopApps" ]] || continue
        id=$(resolve_desktop "$exe" "$name")
        [[ -n "$id" ]] || continue
        while IFS= read -r dir; do
            [[ -f "$dir/$id" ]] && { src="$dir/$id"; break; }
        done < <(desktop_dirs)
        [[ -n "${src:-}" && ! -e "$ddir/$id" ]] || continue
        if [[ "${WOOTC_DRYRUN:-0}" = "1" ]]; then
            printf 'DRYRUN: install desktop launcher %s\n' "$id"
        else
            cp "$src" "$ddir/$id" && chmod +x "$ddir/$id"
            gio set "$ddir/$id" metadata::trusted true 2>/dev/null || true
        fi
        placed=$((placed + 1))
        src=""
    done < <(pinned_lines)
    [[ $placed -gt 0 ]] && log "placed $placed desktop shortcut(s)"
    # Never leak the trailing test's non-zero status: under `set -e` a bare
    # call to this function would abort the script (marker never written → the
    # once-only guard fails and look re-applies every boot).
    return 0
}

# apply_xfce was retired: XFCE is X11 and wootc targets Wayland+systemd only.
# Supported look targets are GNOME, KDE Plasma, and niri (all Wayland).

apply_niri() {
    # Niri is a minimal Wayland compositor: no gsettings/DE registry. Persist
    # wallpaper + keyboard as an overlay the compositor reads on next login.
    local cfgdir="$HOME/.config/wootc"
    if [[ "${WOOTC_DRYRUN:-0}" = "1" ]]; then
        [[ -n "$WALLPAPER" ]] && printf 'DRYRUN: swaybg wallpaper %s\n' "$WALLPAPER"
        [[ -n "$KBD" ]] && printf 'DRYRUN: niri xkb-layout %s\n' "$KBD"
        return
    fi
    mkdir -p "$cfgdir"
    if [[ -n "$WALLPAPER" ]] && command -v swaybg >/dev/null; then
        # A tiny autostart wrapper the niri config can `spawn-at-startup`.
        cat > "$cfgdir/wallpaper.sh" <<EOF
#!/bin/sh
exec swaybg -m fill -i "$WALLPAPER"
EOF
        chmod +x "$cfgdir/wallpaper.sh"
        log "niri: wallpaper set (spawn $cfgdir/wallpaper.sh at startup)"
    fi
    [[ -n "$KBD" ]] && printf 'xkb-layout=%s\n' "$KBD" > "$cfgdir/keyboard.conf"
}

# ── DE detection and dispatch ───────────────────────────────────────────────
DE="${XDG_CURRENT_DESKTOP:-}"
applied=""
case "${DE,,}" in
    *gnome*)          apply_gnome; apply_gnome_favorites; applied=gnome ;;
    *kde*|*plasma*)   apply_kde;   apply_kde_favorites;   applied=kde ;;
    *niri*)           apply_niri;  applied=niri ;;
    *xfce*)
        # XFCE is X11; wootc targets Wayland+systemd only (SPEC scope). The
        # apply_xfce mapping is retired — fall through to unsupported so we
        # don't half-apply an out-of-scope desktop.
        log "desktop '$DE' is X11/out of scope (wootc targets Wayland: GNOME, KDE, niri) — skipping"
        ;;
    *)
        log "desktop '$DE' has no look mapping yet — skipping (add an apply_<de> function)"
        ;;
esac

# Desktop shortcuts are DE-agnostic (freedesktop .desktop on ~/Desktop).
apply_desktop_shortcuts

mkdir -p "$(dirname "$MARKER")"
printf 'de=%s\napplied=%s\nat=%s\n' "$DE" "${applied:-none}" "$(date -u +%FT%TZ)" > "$MARKER"
log "done (de=$DE mapped=${applied:-none})"
