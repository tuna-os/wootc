#!/bin/bash
# /usr/local/bin/wootc-mount-user-dirs
# Bind-mounts Windows user-profile folders (Documents, Pictures, Downloads,
# Music, Videos, Desktop) into the matching Linux user's home directory.
# Runs as wootc-passthrough.service, after wootc-host-bind.service has
# bound the Windows NTFS partition at /host.
#
# Matching is by exact username: the Linux account fisherman created from
# vault.json is expected to share its name with the Windows profile under
# /host/Users/<name>/. A user with no matching Windows profile is skipped
# (not an error — native installs with no prior Windows account are normal).

set -Eeuo pipefail

log() { printf '[wootc-passthrough] %s\n' "$*"; }

FOLDERS=(Documents Pictures Downloads Music Videos Desktop)

if ! mountpoint -q /host; then
    log "ERROR: /host is not mounted (wootc-host-bind.service did not run first)"
    exit 1
fi

# Honour the user's choices from the migration chooser (wootc-manifest-gui).
# sel_on <user> <category> -> 0 when that category should be migrated.
sel_on() {
    command -v wootc-selection >/dev/null || return 0   # helper absent: migrate
    local rc=0
    wootc-selection "$1" "$2" >/dev/null 2>&1 || rc=$?
    # Only an explicit rc=1 means "off"; a broken/unrunnable helper migrates.
    [ "$rc" -eq 1 ] && return 1
    return 0
}

shopt -s nullglob
for winprofile in /host/Users/*/; do
    name=$(basename "$winprofile")
    case "$name" in
        Public|Default|"Default User"|"All Users") continue ;;
    esac

    # Only bind for a Linux account that actually exists (skip unrelated
    # Windows profiles) and has UID >= 1000 (a real user, not a system account).
    uid=$(id -u "$name" 2>/dev/null) || continue
    [[ "$uid" -ge 1000 ]] || continue

    home=$(getent passwd "$name" | cut -d: -f6)
    [[ -d "$home" ]] || continue

    if ! sel_on "$name" files; then
        log "files: skipped for $name (turned off in the migration chooser)"
        continue
    fi

    for folder in "${FOLDERS[@]}"; do
        src="${winprofile}${folder}"
        dst="$home/$folder"
        [[ -d "$src" ]] || continue
        # Converted to native storage (wootc-convert-dir) — stop bridging.
        [[ -e "$home/.config/wootc/converted-$folder" ]] && continue
        mkdir -p "$dst"
        if ! mountpoint -q "$dst"; then
            mount --bind "$src" "$dst"
            log "bound $src -> $dst"
        fi
    done
done
shopt -u nullglob

# Steam category (best-effort — never fail the mount service over it).
if command -v wootc-steam-bridge >/dev/null && sel_on "${SUDO_USER:-root}" games; then
    wootc-steam-bridge || log "steam bridge reported an error (non-fatal)"
elif command -v wootc-steam-bridge >/dev/null; then
    log "games: skipped (turned off in the migration chooser)"
fi

# App-data bridge: per-user detection + portable-state copy (best-effort).
if command -v wootc-detect-apps >/dev/null; then
    shopt -s nullglob
    for userhome in /home/*/; do
        uname=$(basename "$userhome")
        uid=$(id -u "$uname" 2>/dev/null) || continue
        [[ "$uid" -ge 1000 ]] || continue
        wootc-detect-apps "$uname" || log "app detection failed for $uname (non-fatal)"
        if command -v wootc-office-bridge >/dev/null; then
            if sel_on "$uname" office; then
                wootc-office-bridge "$uname" || log "office bridge failed for $uname (non-fatal)"
            else
                log "office: skipped for $uname (turned off in the migration chooser)"
            fi
        fi
        # Copy the account picture + full name over (never the password).
        command -v wootc-identity >/dev/null && \
            { wootc-identity apply "$uname" "$uname" >/dev/null || log "identity copy failed for $uname (non-fatal)"; }
    done
    shopt -u nullglob
fi
