# Build from repo root (so fisherman submodule is in context):
#   podman build -f payload/deployer/Containerfile -t wootc-deployer .
#   podman run --rm --entrypoint /bin/cat localhost/wootc-deployer \
#       /out/initramfs.img > payload/deployer/out/initramfs.img
#
# Output: payload/deployer/out/vmlinuz, payload/deployer/out/initramfs.img (~200MB)

FROM quay.io/fedora/fedora:44 AS builder

# ── Install system packages ─────────────────────────────────────────────────
RUN dnf install -y \
    systemd systemd-udev dracut dracut-network \
    podman skopeo conmon crun netavark aardvark-dns \
    util-linux util-linux-core e2fsprogs dosfstools \
    ntfsprogs \
    parted xfsprogs btrfs-progs \
    kernel-core kernel-modules kernel-modules-extra \
    NetworkManager iproute dhcp-client \
    curl ca-certificates jq \
    qemu-guest-agent psmisc shadow-utils policycoreutils which \
    && dnf clean all

# ── Build fisherman statically ──────────────────────────────────────────────
# Fisherman is a Go binary — build it statically so it needs no runtime deps.
FROM docker.io/library/golang:1.24 AS gobuilder
COPY fisherman /src/fisherman
WORKDIR /src/fisherman/fisherman
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /fisherman ./cmd/fisherman/

# ── Copy fisherman into the initramfs builder ───────────────────────────────
FROM builder
COPY --from=gobuilder /fisherman /usr/bin/fisherman

# ── Deployer script ─────────────────────────────────────────────────────────
COPY payload/deployer/deploy.sh /usr/bin/wootc-deploy
RUN chmod +x /usr/bin/wootc-deploy

 # ── Dracut module ───────────────────────────────────────────────────────────
RUN mkdir -p /usr/lib/dracut/modules.d/99wootc
COPY payload/deployer/module-setup.sh /usr/lib/dracut/modules.d/99wootc/module-setup.sh
COPY payload/deployer/deploy-hook.sh /usr/lib/dracut/modules.d/99wootc/deploy-hook.sh
COPY platform/dracut/99wootc-boot /usr/lib/wootc/99wootc-boot
COPY payload/migration /usr/lib/wootc/migration
RUN chmod +x /usr/lib/dracut/modules.d/99wootc/module-setup.sh /usr/lib/dracut/modules.d/99wootc/deploy-hook.sh

# ── Build the initramfs ─────────────────────────────────────────────────────
RUN printf 'sysloglvl=0\n' > /etc/dracut.conf.d/99-wootc.conf && \
    mkdir -p /out && \
    KERNEL_VER=$(ls /lib/modules | head -1) && \
    dracut \
        --force \
        --no-hostonly \
        --add "network kernel-modules kernel-modules-extra wootc" \
        --install "podman skopeo fisherman \
                   parted mkfs.ext4 mkfs.vfat mkfs.xfs mkfs.btrfs \
                   losetup dmsetup \
                   curl dhclient ip NetworkManager jq blkid chroot shred logger" \
        --kernel-cmdline "rd.neednet=1 ip=dhcp quiet" \
        /out/deployer-initramfs.img \
        "$KERNEL_VER"

# Assert critical binaries actually landed in the image. dracut's
# inst_multiple fails SILENTLY when any one entry is missing (a missing
# restorecon once dropped conmon/crun/podman and cost a full E2E debug
# cycle), so the build must fail loudly here instead.
RUN for bin in conmon crun podman skopeo fisherman sfdisk mkfs.ext4 \
        mkfs.xfs qemu-ga df sync truncate journalctl jq tee which head; do \
        lsinitrd /out/deployer-initramfs.img | grep -q "bin/${bin}$" || \
            { echo "FATAL: ${bin} missing from initramfs"; exit 1; }; \
    done && \
    lsinitrd /out/deployer-initramfs.img | grep -q "etc/pki/tls/certs/ca-bundle.crt" || \
        { echo "FATAL: CA bundle missing from initramfs"; exit 1; } && \
    lsinitrd /out/deployer-initramfs.img | grep -q "usr/lib/wootc/99wootc-boot/wootc-attach-loop.sh" || \
        { echo "FATAL: 99wootc-boot payload missing from initramfs"; exit 1; } && \
    lsinitrd /out/deployer-initramfs.img | grep -q "usr/lib/wootc/migration/wootc-passthrough.service" || \
        { echo "FATAL: User Data Bridge migration payload missing from initramfs"; exit 1; }

RUN cp /boot/vmlinuz-* /out/deployer-vmlinuz 2>/dev/null || \
    cp /lib/modules/*/vmlinuz /out/deployer-vmlinuz 2>/dev/null || true

# Extract: podman run --rm localhost/wootc-deployer cat /out/deployer-vmlinuz > deployer/out/deployer-vmlinuz
# Extract: podman run --rm localhost/wootc-deployer cat /out/deployer-initramfs.img > deployer/out/deployer-initramfs.img
